/// Kingstone Investments - Prisma Schema
/// Database: let (PostgreSQL)
/// This schema defines all database models for the investment platform.

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum UserRole {
  admin
  client
  manager
  analyst
}

enum TransactionType {
  DEPOSIT
  WITHDRAW
  BUY
  SELL
  TRANSFER
  FEE
  REFUND
}

enum TransactionStatus {
  pending
  completed
  failed
  cancelled
}

enum WalletStatus {
  active
  suspended
  closed
  frozen
}

enum OrderStatus {
  pending
  processing
  shipped
  delivered
  cancelled
  refunded
}

enum NotificationType {
  transaction
  investment
  price_alert
  news
  system
  security
}

enum NotificationPriority {
  low
  medium
  high
  urgent
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  BUY
  SELL
}

// ============================================================================
// MODELS
// ============================================================================

model Role {
  id          String   @id @default(uuid())
  name        UserRole @unique
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  users User[]

  @@index([name])
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String    @map("password_hash")
  name              String
  roleId            String?   @map("role_id")
  phone             String?
  company           String?
  country           String?
  avatarUrl         String?   @map("avatar_url")
  virtualBalance    Decimal   @default(0) @db.Decimal(15, 2)
  isEmailVerified   Boolean   @default(false) @map("is_email_verified")
  isActive          Boolean   @default(true) @map("is_active")
  lastLoginAt       DateTime? @map("last_login_at")
  passwordChangedAt DateTime? @map("password_changed_at")
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaSecret         String?   @map("mfa_secret")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  role           Role?           @relation(fields: [roleId], references: [id])
  wallet         Wallet?
  investments    Investment[]
  transactions   Transaction[]
  watchlist      Watchlist[]
  notifications  Notification[]
  sessions       Session[]
  priceAlerts    PriceAlert[]
  marketInsights MarketInsight[] @relation("AuthorInsights")
  productOrders  ProductOrder[]

  @@index([email])
  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

model Sector {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  companies Company[]

  @@index([isActive])
  @@map("sectors")
}

model Region {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  code        String?
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  companies      Company[]
  marketInsights MarketInsight[]

  @@index([isActive])
  @@map("regions")
}

model Company {
  id          String  @id @default(uuid())
  name        String
  symbol      String  @unique
  sectorId    String? @map("sector_id")
  regionId    String? @map("region_id")
  country     String?
  description String?
  logoUrl     String? @map("logo_url")
  website     String?

  // Stock information
  currentPrice  Decimal  @default(0) @map("current_price") @db.Decimal(15, 4)
  previousPrice Decimal? @map("previous_price")
  openPrice     Decimal? @map("open_price")
  highPrice     Decimal? @map("high_price")
  lowPrice      Decimal? @map("low_price")
  volume        BigInt   @default(0)

  // Financial metrics
  marketCap        BigInt?  @map("market_cap")
  peRatio          Decimal? @map("pe_ratio") @db.Decimal(10, 2)
  dividendYield    Decimal? @map("dividend_yield") @db.Decimal(8, 4)
  eps              Decimal? @db.Decimal(10, 4)
  beta             Decimal? @db.Decimal(8, 4)
  fiftyTwoWeekHigh Decimal? @map("fifty_two_week_high")
  fiftyTwoWeekLow  Decimal? @map("fifty_two_week_low")

  // Additional info
  employees    Int?
  foundedYear  Int?    @map("founded_year")
  ceo          String?
  headquarters String?

  // Status
  isActive   Boolean  @default(true) @map("is_active")
  isFeatured Boolean  @default(false) @map("is_featured")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relations
  sector            Sector?             @relation(fields: [sectorId], references: [id])
  region            Region?             @relation(fields: [regionId], references: [id])
  investments       Investment[]
  transactions      Transaction[]
  stockPriceHistory StockPriceHistory[]
  watchlist         Watchlist[]
  priceAlerts       PriceAlert[]

  @@index([symbol])
  @@index([sectorId])
  @@index([regionId])
  @@index([country])
  @@index([isActive])
  @@index([isFeatured])
  @@map("companies")
}

model Investment {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  companyId String @map("company_id")

  // Investment details
  shares           Decimal  @db.Decimal(18, 8)
  buyPrice         Decimal  @map("buy_price") @db.Decimal(15, 4)
  averageCost      Decimal? @map("average_cost") @db.Decimal(15, 4)
  investmentAmount Decimal  @map("investment_amount") @db.Decimal(15, 2)

  // Current values
  currentPrice      Decimal? @map("current_price") @db.Decimal(15, 4)
  currentValue      Decimal? @map("current_value") @db.Decimal(15, 2)
  profitLoss        Decimal? @map("profit_loss") @db.Decimal(15, 2)
  profitLossPercent Decimal? @map("profit_loss_percent") @db.Decimal(10, 4)

  // Status
  isActive Boolean @default(true) @map("is_active")

  // Timestamps
  firstPurchasedAt DateTime  @default(now()) @map("first_purchased_at")
  lastPurchasedAt  DateTime? @map("last_purchased_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@index([isActive])
  @@map("investments")
}

model Wallet {
  id             String       @id @default(uuid())
  userId         String       @unique @map("user_id")
  balance        Decimal      @default(0) @db.Decimal(15, 2)
  pendingBalance Decimal      @default(0) @map("pending_balance") @db.Decimal(15, 2)
  lockedBalance  Decimal      @default(0) @map("locked_balance") @db.Decimal(15, 2)
  currency       String       @default("USD")
  status         WalletStatus @default(active)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  // Relations
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  LedgerEntry  LedgerEntry[]

  @@index([status])
  @@map("wallets")
}

model Transaction {
  id                String            @id @default(uuid())
  walletId          String            @map("wallet_id")
  userId            String            @map("user_id")
  type              TransactionType
  amount            Decimal           @db.Decimal(15, 2)
  fee               Decimal           @default(0) @db.Decimal(15, 2)
  netAmount         Decimal           @map("net_amount") @db.Decimal(15, 2)
  reference         String?           @unique
  provider          String?
  providerReference String?           @map("provider_reference")
  status            TransactionStatus @default(pending)
  description       String?
  metadata          Json              @default("{}")
  requiresApproval  Boolean           @default(false)

  // For BUY/SELL transactions
  companyId     String?  @map("company_id")
  shares        Decimal? @db.Decimal(18, 8)
  pricePerShare Decimal? @map("price_per_share") @db.Decimal(15, 4)

  processedAt DateTime? @map("processed_at")
  completedAt DateTime? @map("completed_at")
  failedAt    DateTime? @map("failed_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  wallet  Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id])

  @@index([walletId])
  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([reference])
  @@index([createdAt])
  @@index([companyId])
  @@map("transactions")
}

model LedgerEntry {
  id           String   @id @default(uuid())
  walletId     String
  userId       String
  type         String // CREDIT, DEBIT, PENDING_CREDIT, PENDING_DEBIT, LOCK
  amount       Decimal  @db.Decimal(15, 2)
  balanceAfter Decimal  @db.Decimal(15, 2)
  reference    String
  description  String?
  metadata     Json?
  createdAt    DateTime @default(now())
  wallet       Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([reference])
  @@index([walletId, createdAt])
  @@map("ledger_entries")
}

model MarketInsight {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  content     String
  summary     String?
  authorId    String?  @map("author_id")
  category    String?
  subcategory String?
  regionId    String?  @map("region_id")
  tags        String[]

  imageUrl String? @map("image_url")
  videoUrl String? @map("video_url")

  isFeatured  Boolean @default(false) @map("is_featured")
  isPublished Boolean @default(false) @map("is_published")
  isPremium   Boolean @default(false) @map("is_premium")

  views  Int @default(0)
  likes  Int @default(0)
  shares Int @default(0)

  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  author User?   @relation("AuthorInsights", fields: [authorId], references: [id])
  region Region? @relation(fields: [regionId], references: [id])

  @@index([category])
  @@index([regionId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([publishedAt])
  @@map("market_insights")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  sku         String? @unique
  description String?

  price          Decimal  @db.Decimal(15, 2)
  compareAtPrice Decimal? @map("compare_at_price") @db.Decimal(15, 2)
  costPerItem    Decimal? @map("cost_per_item") @db.Decimal(15, 2)

  category    String?
  subcategory String?

  images       String[] // Array of URLs
  thumbnailUrl String?  @map("thumbnail_url")

  specifications Json?    @default("{}")
  weight         Decimal? @db.Decimal(10, 2)
  dimensions     Json?

  inventoryQuantity       Int     @default(0) @map("inventory_quantity")
  inventoryAlertThreshold Int     @default(10) @map("inventory_alert_threshold")
  inStock                 Boolean @default(false) @map("in_stock") // Computed
  allowBackorder          Boolean @default(false) @map("allow_backorder")

  isActive   Boolean @default(true) @map("is_active")
  isFeatured Boolean @default(false) @map("is_featured")

  metaTitle       String? @map("meta_title")
  metaDescription String? @map("meta_description")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  orderItems ProductOrderItem[]

  @@index([sku])
  @@index([category])
  @@index([isActive])
  @@index([isFeatured])
  @@map("products")
}

model ProductOrder {
  id          String @id @default(uuid())
  orderNumber String @unique @map("order_number")
  userId      String @map("user_id")

  subtotal       Decimal @db.Decimal(15, 2)
  taxAmount      Decimal @default(0) @map("tax_amount") @db.Decimal(15, 2)
  shippingAmount Decimal @default(0) @map("shipping_amount") @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @map("discount_amount") @db.Decimal(15, 2)
  total          Decimal @db.Decimal(15, 2)

  currency String      @default("USD")
  status   OrderStatus @default(pending)

  // Shipping
  shippingName       String? @map("shipping_name")
  shippingAddress    String? @map("shipping_address")
  shippingCity       String? @map("shipping_city")
  shippingState      String? @map("shipping_state")
  shippingPostalCode String? @map("shipping_postal_code")
  shippingCountry    String? @map("shipping_country")
  shippingPhone      String? @map("shipping_phone")

  // Payment
  paymentMethod    String?   @map("payment_method")
  paymentReference String?   @map("provider_reference")
  paidAt           DateTime? @map("paid_at")

  // Tracking
  trackingNumber String?   @map("tracking_number")
  shippedAt      DateTime? @map("shipped_at")
  deliveredAt    DateTime? @map("delivered_at")

  customerNotes String? @map("customer_notes")
  internalNotes String? @map("internal_notes")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items ProductOrderItem[]

  @@index([orderNumber])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("product_orders")
}

model ProductOrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String? @map("product_id")

  name     String
  sku      String?
  quantity Int     @default(1)
  price    Decimal @db.Decimal(15, 2) // Price at time of order
  total    Decimal @db.Decimal(15, 2)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order   ProductOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product?     @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@index([productId])
  @@map("product_order_items")
}

model Watchlist {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  companyId String @map("company_id")

  targetPrice       Decimal? @map("target_price") @db.Decimal(15, 4)
  priceAlertEnabled Boolean  @default(false) @map("price_alert_enabled")
  note              String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId])
  @@index([companyId])
  @@map("watchlist")
}

model Notification {
  id       String               @id @default(uuid())
  userId   String               @map("user_id")
  type     NotificationType
  priority NotificationPriority @default(medium)
  title    String
  message  String

  entityType String? @map("entity_type")
  entityId   String? @map("entity_id")

  actionUrl String? @map("action_url")

  isRead Boolean   @default(false) @map("is_read")
  readAt DateTime? @map("read_at")

  isEmailSent Boolean @default(false) @map("is_email_sent")
  isPushSent  Boolean @default(false) @map("is_push_sent")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id         String      @id @default(uuid())
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")

  oldValues Json? @map("old_values")
  newValues Json? @map("new_values")

  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")
  sessionId String? @map("session_id")

  description String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model StockPriceHistory {
  id        String @id @default(uuid())
  companyId String @map("company_id")

  date          DateTime
  openPrice     Decimal? @map("open_price") @db.Decimal(15, 4)
  highPrice     Decimal? @map("high_price") @db.Decimal(15, 4)
  lowPrice      Decimal? @map("low_price") @db.Decimal(15, 4)
  closePrice    Decimal? @map("close_price") @db.Decimal(15, 4)
  adjustedClose Decimal? @map("adjusted_close") @db.Decimal(15, 4)
  volume        BigInt   @default(0)

  priceChange        Decimal? @map("price_change") @db.Decimal(15, 4)
  priceChangePercent Decimal? @map("price_change_percent") @db.Decimal(10, 4)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, date])
  @@index([companyId])
  @@index([date])
  @@map("stock_price_history")
}

model PriceAlert {
  id        String @id @default(uuid())
  userId    String @map("user_id")
  companyId String @map("company_id")

  alertType     String   @map("alert_type") // 'above', 'below'
  targetPrice   Decimal? @map("target_price") @db.Decimal(15, 4)
  percentChange Decimal? @map("percent_change") @db.Decimal(10, 2)

  isActive    Boolean   @default(true) @map("is_active")
  isTriggered Boolean   @default(false) @map("is_triggered")
  triggeredAt DateTime? @map("triggered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId, alertType, targetPrice])
  @@index([userId])
  @@index([companyId])
  @@index([isActive])
  @@map("price_alerts")
}

model Session {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  tokenHash String  @map("token_hash")
  ipAddress String? @map("ip_address")
  userAgent String? @map("user_agent")

  isActive Boolean @default(true) @map("is_active")

  expiresAt  DateTime  @map("expires_at")
  lastUsedAt DateTime? @map("last_used_at")

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("sessions")
}

// ============================================================================
// END OF PRISMA SCHEMA
// ============================================================================
