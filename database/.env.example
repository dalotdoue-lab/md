# Kingstone Investments - Environment Configuration

# Copy this file to .env and fill in your values

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Database connection URL (PostgreSQL)
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://let:Mboka@2024@localhost:5432/let"

# Or individual connection parameters (optional, DATABASE_URL takes precedence)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=let

# ============================================================================
# AUTHENTICATION
# ============================================================================

# JWT Secret - Generate with: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# JWT token expiration (default: 7 days)
JWT_EXPIRES_IN=7d

# ============================================================================
# SUPABASE (Optional - for Supabase Auth)
# ============================================================================

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key

# ============================================================================
# STOCK PRICE API (Optional)
# ============================================================================

# Stock API configuration for fetching live prices
# Providers: Alpha Vantage, Twelve Data, Polygon.io, etc.
STOCK_API_KEY=your-stock-api-key
STOCK_API_URL=https://api.example.com

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment
NODE_ENV=development

# Server port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# ============================================================================
# BACKUP CONFIGURATION
# ============================================================================

# Backup directory
BACKUP_DIR=./backups

# Backup retention (days)
BACKUP_RETENTION_DAYS=7

# ============================================================================
# EMAIL CONFIGURATION (Optional)
# ============================================================================

# Email provider (sendgrid, aws-ses, smtp)
EMAIL_PROVIDER=sendgrid
EMAIL_API_KEY=your-email-api-key
EMAIL_FROM=noreply@kingstoneinvestments.com

# ============================================================================
# PAYMENT CONFIGURATION (Optional)
# ============================================================================

# Payment providers
MPESA_CONSUMER_KEY=your-mpesa-key
MPESA_CONSUMER_SECRET=your-mpesa-secret
MPESA_SHORTCODE=your-mpesa-shortcode

STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

